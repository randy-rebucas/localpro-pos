{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(find:*)",
      "Bash(npx next lint:*)",
      "Bash(npx next:*)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run lint:*)",
      "Bash(npx eslint:*)",
      "Bash(npx eslint --max-warnings=0:*)",
      "Bash(ls:*)",
      "Bash(npm run lint)",
      "Bash(node _fix-automation-auth.js)",
      "Bash(node _fix-pagination.js)",
      "Bash(rm _fix-pagination.js)",
      "Read(//c/Users/corew/localpro-pos/**)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)",
      "Bash(npm run:*)",
      "Bash(npm audit:*)",
      "Bash(npm uninstall:*)",
      "Bash(pnpm install:*)",
      "Bash(git log:*)",
      "Bash(pnpm run test)",
      "Bash(pnpm run test:coverage)",
      "Bash(pnpm run build)",
      "Bash(pnpm run health:check)",
      "Bash(pnpm run health:check:verbose)",
      "Bash(npx tsc --noEmit)",
      "Bash(bash .claude/hooks/lint-changed-file.sh)",
      "Bash(bash .claude/hooks/typecheck-before-commit.sh)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-changed-file.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck-before-commit.sh"
          }
        ]
      }
    ]
  }
}
