{
  "name": "pos-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "install:full": "node scripts/install.js",
    "setup": "node scripts/install.js",
    "tenant:create": "tsx scripts/create-tenant.ts",
    "tenant:default": "tsx scripts/create-default-tenant.ts",
    "reset:collections": "tsx scripts/reset-collections.ts",
    "test:automations": "tsx scripts/test-automations.ts",
    "test:customer-auth": "tsx scripts/test-customer-auth.ts",
    "seed:subscription-plans": "tsx scripts/create-subscription-plans.ts",
    "seed:sample-data": "tsx scripts/seed-sample-data.ts",
    "health:check": "tsx scripts/health-check.ts",
    "health:check:verbose": "tsx scripts/health-check.ts --verbose",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security:audit": "npm audit --omit=dev && echo '--- Full audit (including dev) ---' && npm audit",
    "tenant:set-plan": "tsx scripts/set-tenant-plan.ts",
    "load:test:api": "k6 run load-tests/api-endpoints.js",
    "load:test:auth": "k6 run load-tests/auth.js",
    "load:test:transactions": "k6 run load-tests/transactions.js",
    "load:test:mixed": "k6 run load-tests/mixed-workload.js",
    "load:test:all": "k6 run load-tests/api-endpoints.js && k6 run load-tests/mixed-workload.js",
    "load:test:report": "k6 run load-tests/mixed-workload.js --out json=load-tests/results.json --out html=load-tests/results.html",
    "stress:api": "k6 run load-tests/stress-api.js",
    "stress:transactions": "k6 run load-tests/stress-transactions.js",
    "stress:spike": "k6 run load-tests/stress-spike.js",
    "stress:endurance": "k6 run load-tests/stress-endurance.js",
    "stress:all": "k6 run load-tests/stress-api.js && k6 run load-tests/stress-spike.js && k6 run load-tests/stress-endurance.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
